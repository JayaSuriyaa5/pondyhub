# ---------------------------------------------------------------------------
# PondyHub — Environment Variables
# Parent company: SafeShield
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local dev (matches docker-compose.yml service "db")
DATABASE_URL="postgresql://forum_user:forum_password@localhost:5432/forum_db?schema=public"

# ---------------------------------------------------------------------------
# JWT
# ---------------------------------------------------------------------------
# Generate strong random secrets, e.g.: openssl rand -base64 48
JWT_ACCESS_SECRET="replace-with-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Used by server.ts (the custom Node server with Socket.IO attached).
# 0.0.0.0 is required inside Docker so the server accepts connections from
# outside the container, not just localhost within it.
PORT="3000"
HOSTNAME="0.0.0.0"
# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=PondyHub <no-reply@pondyhub.com>

# Email Verification
AUTH_REQUIRE_EMAIL_VERIFICATION=false